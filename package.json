{
  "name": "e-commerce",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "bash scripts/clean-cache.sh",
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "dev:stable": "next dev",
    "dev:clean": "bash scripts/clean-cache.sh && next dev",
    "dev:clean:turbo": "bash scripts/clean-cache.sh && next dev --turbopack",
    "build": "find . -name '._*' -not -path './node_modules/*' -delete 2>/dev/null; next build",
    "build:clean": "bash scripts/clean-cache.sh && npm run build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/lib/db/seed.ts",
    "db:seed:naga": "SEED_REPLACE=1 tsx src/lib/db/seed.ts",
    "db:add-naga-green": "tsx scripts/add-naga-green.ts",
    "db:add-golden-hoodie": "tsx scripts/add-golden-hoodie.ts",
    "db:add-live-test-product": "tsx scripts/add-live-test-product.ts",
    "db:migrate-digital": "tsx scripts/migrate-digital-products.ts",
    "db:prune-catalog": "tsx scripts/prune-catalog.ts",
    "db:update-black-tee-image": "tsx scripts/update-black-tee-image.ts",
    "db:update-white-tee-image": "tsx scripts/update-white-tee-image.ts",
    "generate:product-images": "tsx scripts/generate-product-images.ts",
    "generate:brand-images": "tsx scripts/generate-brand-images.ts",
    "generate:hero-video": "tsx scripts/generate-hero-video.ts",
    "encode:hero-video": "bash scripts/encode-hero-video.sh",
    "encode:hero-clips": "bash scripts/encode-hero-clips.sh",
    "perf:measure": "bash .perf/measure-pages.sh .perf/pages.txt .perf/results-latest.csv",
    "perf:measure:footer": "bash .perf/measure-pages.sh .perf/footer-pages.txt .perf/results-footer.csv"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.1",
    "better-auth": "^1.3.7",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.44.4",
    "lucide-react": "^0.475.0",
    "next": "15.5.19",
    "query-string": "^9.1.1",
    "react": "19.1.8",
    "react-dom": "19.1.8",
    "resend": "^6.16.0",
    "stripe": "^22.2.3",
    "uuid": "^11.1.0",
    "zod": "^4.0.17",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "sharp": "^0.35.2",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
