{
  "name": "e-commerce",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:clean": "rm -rf .next && find . -name '._*' -not -path './node_modules/*' -delete 2>/dev/null; next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/lib/db/seed.ts",
    "db:seed:naga": "SEED_REPLACE=1 tsx src/lib/db/seed.ts",
    "db:add-naga-green": "tsx scripts/add-naga-green.ts",
    "db:add-real-tees": "tsx scripts/add-real-tees.ts",
    "db:prune-catalog": "tsx scripts/prune-catalog.ts",
    "db:set-naga-green-sold-out": "tsx scripts/set-naga-green-sold-out.ts",
    "generate:product-images": "tsx scripts/generate-product-images.ts",
    "generate:brand-images": "tsx scripts/generate-brand-images.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.1",
    "better-auth": "^1.3.7",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.44.4",
    "lucide-react": "^0.475.0",
    "next": "15.5.19",
    "query-string": "^9.1.1",
    "react": "19.1.8",
    "react-dom": "19.1.8",
    "stripe": "^22.2.3",
    "uuid": "^11.1.0",
    "zod": "^4.0.17",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "sharp": "^0.35.2",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
