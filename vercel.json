{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "nagaclub.de" }],
      "destination": "https://www.nagaclub.de/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "header", "key": "x-forwarded-proto", "value": "http" }],
      "destination": "https://www.nagaclub.de/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ]
}
